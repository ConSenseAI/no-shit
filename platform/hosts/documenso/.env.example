# noshit-f0-documenso — environment template.
#
# DO NOT put real secrets here. This file is committed; the real `.env` is
# generated locally by `./setup.sh` (gitignored) with fresh random values.
# Compose reads `.env` from this directory automatically.

# Postgres (INTERNAL network only — never host-published). Password is random.
POSTGRES_PASSWORD=replace-me-run-setup-sh

# Documenso auth + crypto secrets (each a random hex string; >=32 chars for the
# encryption keys). Signed session/CSRF cookies are keyed by NEXTAUTH_SECRET.
NEXTAUTH_SECRET=replace-me-run-setup-sh
NEXT_PRIVATE_ENCRYPTION_KEY=replace-me-run-setup-sh
NEXT_PRIVATE_ENCRYPTION_SECONDARY_KEY=replace-me-run-setup-sh

# Passphrase for the generated local signing certificate (data/cert.p12).
NEXT_PRIVATE_SIGNING_PASSPHRASE=replace-me-run-setup-sh
