# Ghost + Stripe test-clock leg — environment template.
# Copy to .env and fill in a real Stripe *sandbox* restricted test key.
# .env is gitignored; never commit a real key.

# Restricted Stripe test-mode secret key (rk_test_...). Test mode ONLY.
# Needs write scope on: Products, Prices, Customers, Subscriptions,
# PaymentMethods, Invoices, and Test Clocks (test_helpers). Read scope on Events.
STRIPE_SECRET_KEY=rk_test_REPLACE_ME

# Optional: pin the Stripe API version the client sends (determinism).
# Leave unset to use the account default.
# STRIPE_API_VERSION=2024-06-20
