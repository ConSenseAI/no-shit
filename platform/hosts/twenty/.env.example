# noshit-f1-twenty — environment template.
#
# DO NOT put real secrets here. This file is committed; the real `.env` is
# generated locally by `./setup.sh` (gitignored) with fresh random values.
# Compose reads `.env` from this directory automatically.

# Postgres (INTERNAL network only — never host-published). Embedded in Twenty's
# PG_DATABASE_URL, so it MUST be URL-safe (no @ : / etc.). setup.sh uses
# `openssl rand -hex 16`.
POSTGRES_PASSWORD=replace-me-run-setup-sh

# Twenty's application secret (session/token encryption). In Twenty v2.x this is
# ENCRYPTION_KEY (APP_SECRET is legacy, only for instances that pre-date it).
# setup.sh uses `openssl rand -base64 32`, per Twenty's own docs.
ENCRYPTION_KEY=replace-me-run-setup-sh
