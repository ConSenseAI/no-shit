# noshit-f1-formbricks — environment template.
#
# DO NOT put real secrets here. This file is committed; the real `.env` is
# generated locally by `./setup.sh` (gitignored) with fresh random values.
# Compose reads `.env` from this directory automatically.

# Postgres (INTERNAL network only — never host-published). Embedded in
# Formbricks' DATABASE_URL, so it MUST be URL-safe (no @ : / etc.). setup.sh uses
# `openssl rand -hex 16`.
POSTGRES_PASSWORD=replace-me-run-setup-sh

# Formbricks' three required secrets (all `openssl rand -hex 32`):
#   NEXTAUTH_SECRET  — session/JWT signing
#   ENCRYPTION_KEY   — 2FA + single-use survey-link ids
#   CRON_SECRET      — protects the in-container (supercronic) cron endpoints
NEXTAUTH_SECRET=replace-me-run-setup-sh
ENCRYPTION_KEY=replace-me-run-setup-sh
CRON_SECRET=replace-me-run-setup-sh
