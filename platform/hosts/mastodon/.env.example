# noshit-f1-mastodon — environment template.
#
# DO NOT put real secrets here. This file is committed; the real `.env` is
# generated locally by ./setup.sh (gitignored, 0600) using the Mastodon image's
# OWN rake tasks (rake secret, rake mastodon:webpush:generate_vapid_key,
# rake db:encryption:init). Compose reads `.env` from this directory for
# substitution; the shell clients (seed.py/demo.py) source it too.

# --- Postgres (INTERNAL network only — never host-published). Random. ---
POSTGRES_PASSWORD=replace-me-run-setup-sh

# --- Rails / session / MFA secrets (rake secret, x2) ---
SECRET_KEY_BASE=replace-me-run-setup-sh
OTP_SECRET=replace-me-run-setup-sh

# --- Web Push VAPID keypair (rake mastodon:webpush:generate_vapid_key) ---
VAPID_PRIVATE_KEY=replace-me-run-setup-sh
VAPID_PUBLIC_KEY=replace-me-run-setup-sh

# --- ActiveRecord encryption trio, required v4.3+ (rake db:encryption:init) ---
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=replace-me-run-setup-sh
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=replace-me-run-setup-sh
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=replace-me-run-setup-sh

# --- Owner admin (created by tootctl accounts create --confirmed --role Owner) ---
# Identifiers are NOT secret; the password is captured from tootctl (secret).
MASTO_OWNER_USERNAME=noshit_owner
MASTO_OWNER_EMAIL=owner@localhost
MASTO_OWNER_PASSWORD=captured-from-tootctl-at-provision

# --- Shared password set on the deterministic seed/proof accounts (random) ---
# Seed accounts (CSV-export subject) and the per-run archive/deletion accounts
# get this known password so the demo can web-login them (CSV export + archive
# request + deletion confirmation are all session/cookie flows, not OAuth).
MASTO_SEED_PASSWORD=replace-me-run-setup-sh

# --- Owner OAuth token: scopes `read write admin:read admin:write` (minted by ---
# provision/mint_token.rb via rails runner Doorkeeper; secret; never committed). ---
# MASTO_ADMIN_TOKEN=<minted at provision time by demo.sh; secret; never committed>
