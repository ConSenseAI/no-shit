# noshit-f0-killbill — environment template.
# Copy to .env (gitignored) or run ./setup.sh to generate one with a random
# tenant secret. NOTHING here is a real secret: this is a throwaway, test-mode
# stack whose database is never published off the internal compose network.

# --- Image pins ------------------------------------------------------------
# Kill Bill: this tag is verified to honor KILLBILL_SERVER_TEST_MODE=true
# (env-var form of org.killbill.server.test.mode) and expose /1.0/kb/test/clock.
KB_IMAGE=killbill/killbill:0.24.16
# MariaDB with the Kill Bill schema pre-loaded (tag tracks the KB 0.24 line).
DB_IMAGE=killbill/mariadb:0.24
# SMTP sink.
MAILPIT_IMAGE=axllent/mailpit:v1.21.8

# --- MariaDB (internal network only — NEVER host-published) ----------------
# The pre-loaded killbill/mariadb image expects this root password; the demo's
# schema is baked in at this credential. Internal-only, so a known value is fine.
KB_DB_PASSWORD=killbill

# --- Kill Bill admin (default image credentials) ---------------------------
KB_ADMIN_USER=admin
KB_ADMIN_PASSWORD=password

# --- Tenant the demo creates ----------------------------------------------
# The api key is stable; the secret is regenerated by ./setup.sh in the real
# .env. Any values work — this tenant lives only for the demo run.
KB_TENANT_API_KEY=noshit-f0
KB_TENANT_API_SECRET=change-me-in-dot-env

# --- Host port bindings (bound to 127.0.0.1 in compose) --------------------
# Registry (platform/README.md): killbill 8080, mailpit UI 8025 / SMTP 1025.
KB_API_PORT=8080
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
