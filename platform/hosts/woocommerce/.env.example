# noshit-f1-woocommerce — environment template.
#
# DO NOT put real secrets here. This file is committed; the real `.env` is
# generated locally by `./setup.sh` (gitignored) with fresh random values.
# Compose reads `.env` from this directory automatically.

# MariaDB (INTERNAL compose network only — never host-published).
MARIADB_ROOT_PASSWORD=replace-me-run-setup-sh
WORDPRESS_DB_PASSWORD=replace-me-run-setup-sh

# WordPress admin (created by install.sh via `wp core install`).
# The user name and email are not secrets; the password is generated random.
WP_ADMIN_USER=f1admin
WP_ADMIN_PASSWORD=replace-me-run-setup-sh
WP_ADMIN_EMAIL=admin@noshit.test
WP_SITE_TITLE=NoShit F1 Storefront
