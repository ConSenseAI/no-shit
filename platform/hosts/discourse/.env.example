# noshit-f1-discourse — environment template.
#
# DO NOT put real secrets here. This file is committed; the real `.env` is
# generated locally by ./setup.sh (gitignored, 0600). The admin API key
# (DISCOURSE_API_KEY) is MINTED at provision time by provision/admin_seed.rb and
# appended to the real .env by ./demo.sh — it never appears in this example and
# is never printed to the terminal.

# Emails made admin+developer on signup (fixture identifier, NOT a secret). The
# leg also mints the admin directly via a rails runner, so an active admin +
# API key exist without any UI round-trip.
DISCOURSE_DEVELOPER_EMAILS=admin@noshit.test

# The minted admin's username (used as Api-Username by the demo clients).
ADMIN_USERNAME=noshit_admin

# DISCOURSE_API_KEY=<minted at provision time by demo.sh; secret; never committed>
