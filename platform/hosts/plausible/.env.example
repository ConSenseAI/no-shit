# noshit-f1-plausible — environment template.
#
# DO NOT put real secrets here. This file is committed; the real `.env` is
# generated locally by `./setup.sh` (gitignored) with fresh random values.
# Compose reads `.env` from this directory automatically.

# Postgres (INTERNAL network only — never host-published). Password is random hex
# (URL-safe: it is embedded in Plausible's DATABASE_URL).
POSTGRES_PASSWORD=replace-me-run-setup-sh

# Plausible SECRET_KEY_BASE — Phoenix signing/encryption key. Plausible requires
# a >= 64-byte string; setup.sh uses `openssl rand -base64 48`.
SECRET_KEY_BASE=replace-me-run-setup-sh

# Plausible TOTP_VAULT_KEY — 32-byte AES key for the two-factor-auth vault.
# setup.sh uses `openssl rand -base64 32`.
TOTP_VAULT_KEY=replace-me-run-setup-sh
