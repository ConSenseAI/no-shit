# noshit-f1-listmonk — environment template.
#
# DO NOT put real secrets here. This file is committed; the real `.env` is
# generated locally by `./setup.sh` (gitignored) with fresh random values.
# Compose reads `.env` from this directory automatically.

# Postgres (INTERNAL network only — never host-published). Password is random.
POSTGRES_PASSWORD=replace-me-run-setup-sh

# listmonk Super Admin, auto-created on first install and used by the API
# clients (seed.py / demo.py). Username >= 3 chars, password >= 8 chars.
# The password is a random hex string generated by setup.sh.
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=replace-me-run-setup-sh
